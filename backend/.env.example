# === LLM Settings ===
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-lite

# Get free Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional OpenAI key
OPENAI_API_KEY=your_openai_api_key_here

# === App Security ===
# Set a password to protect the Streamlit UI (leave blank to disable auth)
APP_PASSWORD=

# === Data Settings ===
CRICSHEET_DATA_DIR=./data/cricsheet

# === Port Settings ===
STREAMLIT_PORT=8502
BACKEND_PORT=8001
