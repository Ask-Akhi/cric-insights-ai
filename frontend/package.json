{
  "name": "cric-insights-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:capacitor": "vite build --mode capacitor",
    "preview": "vite preview",
    "cap:sync": "npm run build:capacitor && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build": "npm run cap:sync && npx cap open android",
    "cap:sync:ios": "npm run build:capacitor && npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "cap:build:ios": "npm run cap:sync:ios",    "cap:pods": "cd ios/App && pod install && cd ../...",
    "cap:ios:full": "npm run cap:build:ios && npm run cap:pods && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.3",
    "react-type-animation": "^3.2.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
